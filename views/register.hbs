<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT" crossorigin="anonymous">
</head>
<body>
    <!-- Navigation links -->
    <div class="container mt-4">
        <div class="bg-primary">
            <nav class="navbar navbar-expand-lg bg-dark p-2">
                <a class="navbar-brand text-white" href="/">Node MySQL Login</a>
                <ul class="navbar-nav ms-auto"> <!-- This will align the navbar items to the right -->
                    <li class="nav-item"><a class="nav-link text-white" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/register">Register</a></li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Body of the register page -->
    <div class="container mt-4">
        <h2>Register</h2>
        <form action="/auth/register" method="POST">
            <div class="mb-3">
                <label for="name-reg" class="form-label">Name <span style="color:red;">*</span></label>
                <input type="text" class="form-control" id="name-reg" name="name">
            </div>
            <div class="mb-3">
                <label for="email-reg" class="form-label">Email <span style="color:red;">*</span></label>
                <input type="text" class="form-control" id="email-reg" name="email">
            </div>
            <div class="mb-3">
                <label for="password-reg" class="form-label">Password <span style="color:red;">*</span></label>
                <input type="password" class="form-control" id="password-reg" name="password">
            </div>
            <div class="mb-3">
                <label for="password-conf-reg" class="form-label">Confirm Password <span style="color:red;">*</span></label>
                <input type="password" class="form-control" id="password-conf-reg" name="passwordConfirm">
            </div>
            <div class="mb-3">
                <label for="remarks-reg" class="form-label">Remarks <span style="color:green;">(optional)</span></label>
                <input type="remarks" class="form-control" id="remarks-reg" name="remarks">
            </div>

            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</body>
</html>
