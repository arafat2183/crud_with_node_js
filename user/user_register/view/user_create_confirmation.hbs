<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT" crossorigin="anonymous">
    <style>
        .success {
            color: green;
            font-weight: bold;
        }
        .error {
            color: red;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <!-- Navigation links -->
    <div class="container mt-4">
        <div class="bg-primary">
            <nav class="navbar navbar-expand-lg bg-dark p-2">
                <a class="navbar-brand text-white" href="/">Node MySQL Login</a>
                <ul class="navbar-nav ms-auto"> <!-- This will align the navbar items to the right -->
                    <li class="nav-item"><a class="nav-link text-white" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/register">Register</a></li>
                </ul>
            </nav>
        </div>

        <h1 class="text-center">Registration Confirmation</h1>

        <div>
            <!-- Check if status exists, then display the message accordingly -->
            {{#if status}}
                {{#if (eq status "success")}}
                    <div class="success text-center">
                        {{message}}
                    </div>
                {{else}}
                    <div class="error text-center">
                        {{message}}
                    </div>
                {{/if}}
            {{/if}}

            <!-- You can also display user details if the registration was successful -->
            {{#if status}}
                {{#if (eq status "success")}}
                    <p class="text-center">User Name: {{name}}</p>
                    <p class="text-center">User Email: {{email}}</p>
                {{/if}}
            {{/if}}
        </div>
    </div>

</body>
</html>
